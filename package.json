{
  "name": "quality.md-workspace",
  "version": "0.32.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build --compile --outfile=dist/qualitymd src/main.ts",
    "build:release": "bun scripts/build-release.ts",
    "check": "bun run fmt:check && bun run typecheck && bun run lint && bun run test",
    "fmt": "oxfmt --write src test scripts/*.ts vitest.config.ts tsconfig.json package.json",
    "fmt:check": "oxfmt --check src test scripts/*.ts vitest.config.ts tsconfig.json package.json",
    "lint": "oxlint --deny-warnings src test scripts/*.ts vitest.config.ts",
    "run": "bun run src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.209",
    "@effect/platform-bun": "4.0.0-beta.98",
    "@openai/codex-sdk": "0.144.4",
    "ajv": "8.17.1",
    "effect": "4.0.0-beta.98",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@effect/language-service": "0.87.0",
    "@effect/vitest": "4.0.0-beta.98",
    "@types/bun": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "bun@1.3.14"
}
