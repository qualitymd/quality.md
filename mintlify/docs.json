{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "QUALITY.md",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": {
    "light": "/images/favicon-light.svg",
    "dark": "/images/favicon-dark.svg"
  },
  "colors": {
    "primary": "#5B68EE",
    "light": "#A4ACF2",
    "dark": "#5B68EE"
  },
  "banner": {
    "content": "👋🧪 Welcome! QUALITY.md is an experimental project to make the practice of maintenance more agent and human friendly. [Join in](https://github.com/qualitymd/quality.md/discussions).",
    "dismissible": true
  },
  "redirects": [
    {
      "source": "/install.ps1",
      "destination": "https://raw.githubusercontent.com/qualitymd/quality.md/main/install/install.ps1",
