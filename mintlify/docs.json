    },
    {
      "source": "/install.cmd",
      "destination": "https://raw.githubusercontent.com/qualitymd/quality.md/main/install/install.cmd",
      "permanent": false
    }
  ],
  "navigation": {
    "pages": [
      "index",
      "quickstart",
      {
        "group": "The Quality Loop",
        "pages": ["loops", "claude-code", "codex"]
